# Telegram credentials
# Keep real values in a local .env file or Railway Variables.
TELEGRAM_BOT_TOKEN=
AUTHORIZED_TELEGRAM_USER_ID=

# Storage
DATABASE_PATH=./data/rental_alert.db

# Polling and request behavior
POLL_INTERVAL_SECONDS=300
POLL_JITTER_SECONDS=30
REQUEST_TIMEOUT_SECONDS=20

# Telegram delivery
INITIAL_NOTIFICATION_BATCH_SIZE=10
TELEGRAM_SEND_DELAY_SECONDS=1.2

# Operations
FAILURE_ALERT_THRESHOLD=3
LOG_LEVEL=INFO
TZ=Asia/Taipei

# Railway healthcheck
# Railway sets PORT automatically. Leave blank for local runs unless you want /health.
PORT=
HEALTHCHECK_PATH=/health
